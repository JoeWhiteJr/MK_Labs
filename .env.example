# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mkl_platform

# Auth
JWT_SECRET=             # Generate: openssl rand -hex 32
JWT_EXPIRY=7d

# LLM (optional — AI features disabled if not set)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Email (optional — emails logged only if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=              # Google App Password (not regular password)
SMTP_FROM=
CONTACT_EMAIL=          # Where contact form submissions are sent

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Uploads
UPLOAD_DIR=./uploads
